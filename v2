<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>LifeOS - Bhavya</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://unpkg.com/react@18/umd/react.development.js"></script>
<script src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
<script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
<style>
@keyframes pop{0%{transform:scale(.8);opacity:0}50%{transform:scale(1.15)}100%{transform:scale(1);opacity:1}}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}
@keyframes glow{0%,100%{filter:brightness(1)}50%{filter:brightness(1.25)}}
@keyframes slide{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
.animate-pop{animation:pop.35s ease-out}
.animate-float{animation:float 3s ease-in-out infinite}
.animate-glow{animation:glow 2s infinite}
.animate-slide{animation:slide.4s ease-out}
body{background:#050507;color:#fff;margin:0;font-family:system-ui,-apple-system,BlinkMacSystemFont;overscroll-behavior:none}
.glass{background:rgba(18,18,26,.88);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,.08)}
.bhavya-bg{background:radial-gradient(ellipse at top,rgba(0,255,170,.18),transparent 60%)}
.btn{transition:all.15s ease}
.btn:active{transform:scale(.96)}
*{-webkit-tap-highlight-color:transparent}
</style>
</head>
<body>
<div id="root"></div>
<script type="text/babel">
const {useState,useEffect}=React;
function App(){
  const [player,setPlayer]=useState(()=>{const s=localStorage.getItem('lifeos_final');return s?JSON.parse(s).p:{xp:0,l:1,h:0,m:0,s:0,g:0,d:1,hx:0,mx:0,sx:0,gx:0,str:0,tt:0,satan:0,bhavya:1,asc:0}});
  const [tasks,setTasks]=useState(()=>{const s=localStorage.getItem('lifeos_final');return s?JSON.parse(s).t:[{i:1,n:"Physical Training",x:60,st:"s",c:0,su:[{t:"Cardio",d:0},{t:"Muscle",d:0}]},{i:2,n:"Hygiene",x:40,st:"h",c:0,su:[{t:"Brush day",d:0},{t:"Brush night",d:0},{t:"Sleep 8h",d:0},{t:"Bath",d:0}]},{i:3,n:"Core Work",x:80,st:"m",c:0,su:[{t:"Studying",d:0}]}]});
  const [gods,setGods]=useState(()=>{const s=localStorage.getItem('lifeos_final');return s?JSON.parse(s).g:[{i:1,n:"Hygeia",e:"🌿",x:0,nd:2500000,c:"#10B981",ti:"Lifelong Health",a:0},{i:2,n:"Ryan Howard",e:"💼",x:0,nd:1500000,c:"#64748B",ti:"The Temp",a:0},{i:3,n:"Sisyphus",e:"⛰️",x:0,nd:900000,c:"#6366F1",ti:"JEE AIR 1",a:0},{i:4,n:"Jordan Belfort",e:"🐺",x:0,nd:750000,c:"#F59E0B",ti:"Sell the Book",a:0},{i:5,n:"Albert Camus",e:"📖",x:0,nd:2500000,c:"#8B5CF6",ti:"Lifelong Creator",a:0},{i:6,n:"Spidey",e:"🕷️",x:0,nd:2500000,c:"#EF4444",ti:"Lifelong Physique",a:0},{i:7,n:"Lewandowski",e:"🤖",x:0,nd:600000,c:"#DC2626",ti:"The Robot",a:0}]});
  const [sins,setSins]=useState(()=>{const s=localStorage.getItem('lifeos_final');return s?JSON.parse(s).si:[{i:1,t:"Fapped",d:0,w:15},{i:2,t:"Skipped grind",d:0,w:15},{i:3,t:"did something bad",d:0,w:50}]});
  const [events,setEvents]=useState(()=>{const s=localStorage.getItem('lifeos_final');const ev=s?JSON.parse(s).ev:null;return ev||[{i:1,n:"BITSAT 2026",e:"🎯",xp:15000,daysTotal:25,daysLeft:25,completed:false}]});
  const [tab,setTab]=useState('tasks');const [msg,setMsg]=useState('');const [pop,setPop]=useState(null);const [showAdd,setShowAdd]=useState(false);const [nt,setNt]=useState({n:'',x:50,st:'m'});const [showEventAdd,setShowEventAdd]=useState(false);const [ne,setNe]=useState({n:'',e:'🎯',xp:5000,days:30});
  useEffect(()=>{localStorage.setItem('lifeos_final',JSON.stringify({p:player,t:tasks,g:gods,si:sins,ev:events}))},[player,tasks,gods,sins,events]);
  const toast=(t,x,y)=>{setMsg(t);if(x)setPop({t,x,y});setTimeout(()=>{setMsg('');setPop(null)},1300)};
  const claim=(id,e)=>{const r=e.currentTarget.getBoundingClientRect();setTasks(ts=>ts.map(t=>{if(t.i!==id)return t;const d=t.su.filter(s=>s.d).length;if(!d)return t;const earn=Math.floor(t.x*d/t.su.length);toast(`+${earn}`,r.left+20,r.top);setPlayer(p=>{const inc=p.bhavya<10?0.2:0.02;return{...p,xp:p.xp+earn,l:Math.floor((p.xp+earn)/100)+1,[t.st]:p[t.st]+1,[t.st+'x']:p[t.st+'x']+earn,tt:p.tt+1,bhavya:p.bhavya+inc}});return{...t,c:t.c+1,su:t.su.map(s=>({...s,d:0}))}}))};
  const toggle=(tid,i)=>setTasks(ts=>ts.map(t=>t.i===tid?{...t,su:t.su.map((s,idx)=>idx===i?{...s,d:!s.d}:s)}:t));
  const give=(gid,st)=>{if(player[st+'x']<25)return;setPlayer(p=>({...p,[st+'x']:p[st+'x']-25}));setGods(gs=>gs.map(g=>{if(g.i!==gid)return g;const nx=g.x+25;if(nx>=g.nd){toast(`ASCENDED! +1 BHAVYA`);setPlayer(p=>({...p,bhavya:Math.floor(p.bhavya)+1,asc:p.asc+1}));return{...g,x:0,nd:Math.floor(g.nd*1.5),a:g.a+1}}return{...g,x:nx}}))};
  const sinToggle=id=>{setSins(ss=>{const ns=ss.map(s=>s.i===id?{...s,d:!s.d}:s);setPlayer(p=>({...p,satan:Math.min(100,ns.filter(x=>x.d).reduce((a,b)=>a+b.w,0))}));return ns})};
  const sleep=()=>{const s=player.satan;if(s===0){setPlayer(p=>({...p,xp:p.xp+10}));toast('+10 Pure Day')}else if(s>=50){setPlayer(p=>({...p,xp:Math.max(0,p.xp-30),str:0}));toast('-30 Corrupted')}setPlayer(p=>({...p,d:p.d+1,str:s<30?p.str+1:0}));setTasks(ts=>ts.map(t=>({...t,su:t.su.map(x=>({...x,d:0}))})));setSins(ss=>ss.map(x=>({...x,d:0})));setEvents(es=>es.map(ev=>ev.completed?ev:{...ev,daysLeft:Math.max(0,ev.daysLeft-1)}).filter(ev=>ev.completed||ev.daysLeft>=0))};
  const addTask=()=>{if(!nt.n.trim())return;setTasks(t=>[...t,{i:Date.now(),n:nt.n,x:+nt.x,st:nt.st,c:0,su:[{t:"Do it",d:0}]}]);setNt({n:'',x:50,st:'m'});setShowAdd(false);toast('Task added')};
  const addSub=tid=>{const v=prompt('Subtask name:');if(v)setTasks(ts=>ts.map(t=>t.i===tid?{...t,su:[...t.su,{t:v,d:0}]}:t))};
  const deleteTask=id=>{if(confirm('Delete task?')){setTasks(ts=>ts.filter(t=>t.i!==id));toast('Deleted')}};
  const completeEvent=id=>{setEvents(es=>es.map(ev=>{if(ev.i!==id||ev.completed||ev.daysLeft>0)return ev;toast(`+${ev.xp.toLocaleString()}!`);setPlayer(p=>({...p,xp:p.xp+ev.xp,bhavya:p.bhavya+2,asc:p.asc+1}));return{...ev,completed:true}}))};
  const addEvent=()=>{if(!ne.n.trim())return;setEvents(e=>[...e,{i:Date.now(),n:ne.n,e:ne.e,xp:+ne.xp,daysTotal:+ne.days,daysLeft:+ne.days,completed:false}]);setNe({n:'',e:'🎯',xp:5000,days:30});setShowEventAdd(false);toast('Event added')};
  const deleteEvent=id=>{if(confirm('Delete event?')){setEvents(es=>es.filter(ev=>ev.i!==id));toast('Deleted')}};
  const resetAll=()=>{if(confirm('RESET ALL?')&&confirm('Really delete everything?')){localStorage.removeItem('lifeos_final');location.reload()}};

  return(<div className="min-h-screen max-w-[420px] mx-auto relative select-none"><div className="absolute inset-0 bhavya-bg pointer-events-none"/>{msg&&<div className="fixed top-5 left-1/2 -translate-x-1/2 bg-[#00FFAA] text-black px-5 py-2 rounded-full font-black text-sm z-50 animate-pop">{msg}</div>}{pop&&<div className="fixed pointer-events-none text-[#00FFAA] font-black text-2xl z-50 animate-pop" style={{left:pop.x,top:pop.y-30}}>{pop.t}</div>}
    <div className="relative z-10 p-4 pb-24">
      <div className="text-center pt-3 pb-5 animate-slide"><div className="text-5xl animate-float mb-1">👑</div><h1 className="text-[42px] font-black leading-none tracking-tighter bg-gradient-to-r from-[#00FFAA] via-cyan-300 to-[#00FFAA] bg-clip-text text-transparent animate-glow">BHAVYA</h1><p className="text-[11px] uppercase tracking-[0.2em] opacity-50 mt-1">Level {Math.floor(player.bhavya)} • {player.asc} Wins</p><div className="flex justify-center gap-8 mt-4"><div><p className="text-[10px] opacity-40">DAY</p><p className="text-xl font-bold">{player.d}</p></div><div><p className="text-[10px] opacity-40">STREAK</p><p className="text-xl font-bold">🔥{player.str}</p></div><div><p className="text-[10px] opacity-40">SATAN</p><p className="text-xl font-bold text-red-500">{player.satan}%</p></div></div></div>
      <div className="glass rounded-2xl p-1 flex gap-1 mb-4 sticky top-3 z-40">{['tasks','gods','events','satan','stats'].map(t=><button key={t} onClick={()=>setTab(t)} className={`flex-1 py-2.5 rounded-xl text-[11px] font-bold capitalize btn ${tab===t?'bg-white text-black':'text-white/60'}`}>{t}</button>)}</div>

      {tab==='tasks'&&<div className="space-y-3">{tasks.map((t,idx)=>{const d=t.su.filter(s=>s.d).length;return<div key={t.i} className="glass rounded-[28px] p-4 animate-slide" style={{animationDelay:idx*40+'ms'}}><div className="flex justify-between items-start"><div><h3 className="font-bold text-[15px] flex items-center gap-2">{t.n}{t.c>0&&<span className="text-[10px] px-1.5 py-0.5 rounded-full bg-white/10">{t.c}</span>}</h3><p className="text-[11px] opacity-50 mt-0.5">+{t.x} XP • {d}/{t.su.length}</p></div><div className="flex gap-1.5"><button onClick={e=>claim(t.i,e)} disabled={!d} className={`btn px-4 py-2 rounded-2xl text-[13px] font-bold ${d?'bg-[#00FFAA] text-black':'bg-zinc-800 text-zinc-600'}`}>Claim</button><button onClick={()=>deleteTask(t.i)} className="btn w-8 h-8 rounded-2xl bg-red-950/50 hover:bg-red-900/70 text-red-400">×</button></div></div><div className="mt-3.5 space-y-2.5">{t.su.map((s,i)=><button key={i} onClick={()=>toggle(t.i,i)} className="flex items-center gap-3 w-full text-left"><div className={`w-[22px] h-[22px] rounded-xl border-2 flex items-center justify-center ${s.d?'bg-[#00FFAA] border-[#00FFAA]':'border-white/20'}`}>{s.d&&<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 6l2 2 4-4" stroke="#000" strokeWidth="2" strokeLinecap="round"/></svg>}</div><span className={`text-[14px] ${s.d?'line-through opacity-40':'opacity-85'}`}>{s.t}</span></button>)}</div><button onClick={()=>addSub(t.i)} className="mt-3 text-[11px] opacity-35">+ add subtask</button></div>})}
      {showAdd?<div className="glass rounded-[28px] p-4 space-y-3"><input autoFocus value={nt.n} onChange={e=>setNt({...nt,n:e.target.value})} placeholder="New task..." className="w-full bg-black/60 border border-white/10 rounded-xl px-3.5 py-2.5 text-[14px] outline-none"/><div className="flex gap-2"><input type="number" value={nt.x} onChange={e=>setNt({...nt,x:e.target.value})} className="w-24 bg-black/60 border border-white/10 rounded-xl px-3 py-2.5"/><select value={nt.st} onChange={e=>setNt({...nt,st:e.target.value})} className="flex-1 bg-black/60 border border-white/10 rounded-xl px-3 py-2.5"><option value="h">❤️ Health</option><option value="m">🧠 Mana</option><option value="s">⚡ Stamina</option><option value="g">💰 Gold</option></select></div><div className="flex gap-2"><button onClick={addTask} className="flex-1 btn bg-[#00FFAA] text-black font-bold py-2.5 rounded-xl">Add</button><button onClick={()=>setShowAdd(false)} className="px-4 btn bg-white/10 rounded-xl">Cancel</button></div></div>:<button onClick={()=>setShowAdd(true)} className="w-full glass rounded-[28px] py-3.5 font-semibold text-[14px] opacity-75 btn">+ Add New Task</button>}
      <button onClick={sleep} className="w-full mt-2 bg-gradient-to-b from-violet-900 via-purple-900 to-violet-950 border-violet-800/50 rounded-[28px] py-4 font-bold text-[15px] btn">🌙 Sleep — End Day {player.d}</button></div>}

      {tab==='gods'&&<div className="space-y-3">{gods.map((g,i)=>{const pct=Math.min(99.9,g.x/g.nd*100);return<div key={g.i} className="glass rounded-[28px] p-4"><div className="flex gap-3.5"><div className="text-[32px]">{g.e}</div><div className="flex-1"><div className="flex justify-between"><h3 className="font-bold">{g.n}</h3><span className="text-[10px] px-1.5 py-0.5 rounded-full bg-white/10">{g.a}×</span></div><p className="text-[11px] opacity-50">{g.ti}</p><div className="mt-3"><div className="flex justify-between text-[10px] mb-1"><span className="opacity-60">{Math.floor(g.x/1000)}k / {Math.floor(g.nd/1000)}k</span><span className="opacity-40">{pct.toFixed(1)}%</span></div><div className="h-[7px] bg-black/80 rounded-full overflow-hidden"><div className="h-full" style={{width:pct+'%',background:g.c}}/></div></div><div className="grid grid-cols-4 gap-1.5 mt-3">{['h','m','s','g'].map(st=><button key={st} disabled={player[st+'x']<25} onClick={()=>give(g.i,st)} className="btn bg-black/60 disabled:opacity-25 border border-white/5 rounded-xl py-1.5 text-[11px]">{st==='h'?'❤️':st==='m'?'🧠':st==='s'?'⚡':'💰'} {player[st+'x']}</button>)}</div></div></div></div>})}</div>}

      {tab==='events'&&<div className="space-y-3">{events.map(ev=>{const pct=((ev.daysTotal-ev.daysLeft)/ev.daysTotal)*100;const can=ev.daysLeft===0&&!ev.completed;return<div key={ev.i} className="glass rounded-[28px] p-5 relative"><button onClick={()=>deleteEvent(ev.i)} className="absolute top-3 right-3 w-7 h-7 rounded-lg bg-black/40 hover:bg-red-900/60 text-white/50 hover:text-red-400 btn">×</button><div className="flex items-start gap-4 pr-8"><div className="text-[42px]">{ev.e}</div><div className="flex-1"><h3 className="font-black text-[20px]">{ev.n}</h3><p className={`text-[11px] mt-0.5 ${ev.completed?'text-[#00FFAA]':can?'text-amber-400':'opacity-60'}`}>{ev.completed?'COMPLETED':can?'READY':`${ev.daysLeft} DAYS LEFT`}</p><div className="mt-3"><div className="h-[8px] bg-black/80 rounded-full overflow-hidden"><div className="h-full" style={{width:pct+'%',background:can?'#fbbf24':'#00FFAA'}}/></div></div><div className="flex justify-between items-center mt-3"><span className="text-[15px] font-bold text-[#00FFAA]">+{ev.xp.toLocaleString()} XP</span><button disabled={!can} onClick={()=>completeEvent(ev.i)} className={`btn px-5 py-2 rounded-2xl text-[13px] font-bold ${can?'bg-amber-400 text-black':'bg-zinc-800 text-zinc-500'}`}>{ev.completed?'Done':can?'CLAIM':`${ev.daysLeft}d`}</button></div></div></div></div>})}
      {showEventAdd?<div className="glass rounded-[28px] p-4 space-y-3"><input autoFocus value={ne.n} onChange={e=>setNe({...ne,n:e.target.value})} placeholder="Event name" className="w-full bg-black/60 border border-white/10 rounded-xl px-3.5 py-2.5"/><div className="flex gap-2"><input value={ne.e} onChange={e=>setNe({...ne,e:e.target.value})} className="w-16 text-center bg-black/60 border border-white/10 rounded-xl py-2.5"/><input type="number" value={ne.xp} onChange={e=>setNe({...ne,xp:e.target.value})} className="flex-1 bg-black/60 border border-white/10 rounded-xl px-3 py-2.5"/><input type="number" value={ne.days} onChange={e=>setNe({...ne,days:e.target.value})} className="w-20 bg-black/60 border border-white/10 rounded-xl px-3 py-2.5"/></div><div className="flex gap-2"><button onClick={addEvent} className="flex-1 btn bg-amber-400 text-black font-bold py-2.5 rounded-xl">Add</button><button onClick={()=>setShowEventAdd(false)} className="px-4 btn bg-white/10 rounded-xl">Cancel</button></div></div>:<button onClick={()=>setShowEventAdd(true)} className="w-full glass rounded-[28px] py-3.5 font-semibold text-[14px] opacity-75 btn">+ Add Timed Event</button>}</div>}

      {tab==='satan'&&<div className="space-y-4"><div className="glass rounded-[28px] p-6 text-center"><div className="text-5xl mb-2">😈</div><h2 className="text-xl font-black text-red-500">SATAN</h2><div className="mt-4 w-full h-3 bg-black/90 rounded-full overflow-hidden"><div className="h-full bg-red-600" style={{width:player.satan+'%'}}/></div><p className="text-[11px] opacity-60 mt-2">{player.satan}%</p></div><div className="space-y-2">{sins.map(s=><button key={s.i} onClick={()=>sinToggle(s.i)} className={`w-full glass rounded-2xl p-3.5 flex items-center gap-3 btn ${s.d?'bg-red-950/25':''}`}><div className={`w-5 h-5 rounded-lg border-2 flex items-center justify-center ${s.d?'bg-red-600 border-red-500':'border-white/25'}`}>{s.d&&'✕'}</div><span className="flex-1">{s.t}</span><span className={`text-[11px] px-2 py-1 rounded-full ${s.d?'bg-red-950/60 text-red-300':'bg-black/60'}`}>+{s.w}%</span></button>)}</div></div>}

      {tab==='stats'&&<div className="grid grid-cols-2 gap-3"><div className="glass rounded-[28px] p-5 col-span-2 text-center"><p className="text-[11px] opacity-50">TOTAL XP</p><p className="text-[36px] font-black text-[#00FFAA]">{player.xp}</p></div><div className="col-span-2"><button onClick={resetAll} className="w-full glass rounded-2xl py-3.5 font-bold text-[13px] text-red-400 hover:bg-red-950/20 btn">⚠️ Reset All Progress</button></div></div>}
    </div></div>);
}
ReactDOM.createRoot(document.getElementById('root')).render(<App/>);
</script>
</body>
</html>
